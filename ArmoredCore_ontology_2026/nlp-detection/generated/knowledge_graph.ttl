ex:C4_621 a ex:Character,
        ex:Entity,
        ex:Human ;
    rdfs:label "C4-621" ;
    ex:hasAlias ex:Alias_Ashbringer,
        ex:Alias_Buddy,
        ex:Alias_C4_621,
