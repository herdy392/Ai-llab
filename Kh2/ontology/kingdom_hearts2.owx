        <NamedIndividual IRI="#DestinyIslands"/>
        <Literal datatypeIRI="&xsd;string">DestinyIslands</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#description"/>
        <NamedIndividual IRI="#DisneyCastle"/>
        <Literal datatypeIRI="&xsd;string">The royal home of Mickey, Donald and Goofy. Threatened by the Heartless, it becomes a key point to protect the Light and maintain balance between worlds.</Literal>
    </DataPropertyAssertion>
