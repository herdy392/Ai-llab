    <DataPropertyAssertion>
        <DataProperty IRI="#description"/>
        <NamedIndividual IRI="#Riku"/>
        <Literal datatypeIRI="&xsd;string">Riku in KH2 is a character marked by his past: more mature, tormented and determined. After struggling against Darkness, he accepts the weight of his choices and fights in the shadows to protect Sora.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
