    <DataPropertyAssertion>
        <DataProperty IRI="#description"/>
        <NamedIndividual IRI="#Donald"/>
        <Literal datatypeIRI="&xsd;string">Donald is the court mage and the most impulsive member of the group. In KH2 he is energetic, straightforward and often comically irritable, but deeply fond of his companions. Specialized in offensive and healing magic, he is the main magical support of the team. Despite his explosive temper, he shows enormous courage and unwavering dedication to the mission.</Literal>
    </DataPropertyAssertion>
