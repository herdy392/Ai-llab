    <DataPropertyAssertion>
        <DataProperty IRI="#description"/>
        <NamedIndividual IRI="#RadiantGarden"/>
        <Literal datatypeIRI="&xsd;string">Once a stronghold of Darkness, now under reconstruction. It is the operational center of Sora&apos;s old friends and the stage for crucial battles against Heartless, Nobodies and Organization XIII.</Literal>
    </DataPropertyAssertion>
